pub fn clear_input(client) {
    var response = gen_tcp.recv(client, 0)
    var raw_data = response[2]
    var bytes_size = byte_size(raw_data) - 1
    var cleaned_data = binary_part(raw_data, 0, bytes_size)
    var parsed_data = binary_to_list(cleaned_data)
    var trimmed_data = string.trim(parsed_data)

    return trimmed_data
}
